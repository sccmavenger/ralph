{
  "name": "msf-companion-functions",
  "version": "1.0.0",
  "description": "MSF Companion Intelligence Pipeline — Azure Functions",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run build",
    "start": "func start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.2",
    "@azure/functions": "^4.6.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
