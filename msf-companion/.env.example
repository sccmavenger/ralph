# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/msf_companion?schema=public"

# Session encryption secret (minimum 32 characters)
SESSION_SECRET="change-me-to-a-random-32-char-string!"

# Scopely OAuth
SCOPELY_CLIENT_ID="your-scopely-client-id"
SCOPELY_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# MSF API key (server-side only — never expose to browser)
MSF_API_KEY="your-msf-api-key"

# Set to PREMIUM to bypass paywall for testing
# OVERRIDE_TIER=PREMIUM

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (transactional email)
RESEND_API_KEY="re_..."
EMAIL_FROM="MSF Companion <info@msftoolkit.com>"

# Admin Panel
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_SESSION_SECRET="change-me-to-a-random-32-char-string!"

# Discord Bot (announcements)
DISCORD_BOT_TOKEN=""
DISCORD_ANNOUNCEMENT_CHANNEL_ID=""
